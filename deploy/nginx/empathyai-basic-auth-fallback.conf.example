# Optional operator-only fallback for manual testing.
#
# Do not enable this file on the same public host/port used by the tokenized
# demo flow. Basic Auth on the public route prevents users launched from GitHub
# Pages from entering with demo_token links.
#
# Safer manual fallback options:
# - SSH into the VM and use a local tunnel to Streamlit.
# - Temporarily swap the active Nginx config during operator testing only.
# - Bind this server to a private interface or firewall it to an operator IP.

server {
    listen 8080;
    server_name _;

    auth_basic "EmpathyAI operator fallback";
    auth_basic_user_file /etc/nginx/.htpasswd-empathyai;

    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
}
